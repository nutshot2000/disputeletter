# ============================================
# DisputeLetter.org Environment Variables
# ============================================

# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=""

# STRIPE_SECRET_KEY: Required for processing payments.
# Get yours at: https://dashboard.stripe.com/apikeys (use Test keys for development)
STRIPE_SECRET_KEY="sk_test_..."

# VITE_STRIPE_PUBLISHABLE_KEY: Required for frontend Stripe Elements.
# This is the 'Publishable key' from your Stripe dashboard
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# RESEND_API_KEY: Optional - for sending email confirmations.
# Get yours at: https://resend.com (free tier: 3,000 emails/month)
RESEND_API_KEY=""
